# Copy to .env for LOCAL runs:  cp .env.example .env
# In GitHub Actions you do NOT use this file — add these as repository secrets
# (Settings → Secrets and variables → Actions). Never commit a real .env.

# Required: your free Trends MCP key — https://trendsmcp.ai
TRENDS_API_KEY=

# Optional notification channels (configure only what you use):
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP) — e.g. Gmail app password, Fastmail, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=

# Any other system (Zapier, Make, n8n, your own endpoint):
GENERIC_WEBHOOK_URL=
